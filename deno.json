{
  "name": "@whyk/feeder",
  "version": "0.1.0",
  "exports": {
    "./core": "./mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-net",
    "test:watch": "deno test --allow-read --allow-write --allow-net --watch",
    "test:coverage": "deno test --allow-read --allow-write --allow-net --coverage=coverage",
    "coverage": "deno coverage coverage --html",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check **/*.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/testing": "jsr:@std/testing@^1.0.15"
  },
  "fmt": {
    "exclude": ["README.md", ".kiro/specs/feeder/*.md"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
